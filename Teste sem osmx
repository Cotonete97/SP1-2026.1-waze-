#6-Esqueleto(executor do dijkstra):
def dijkstra(caminhos, inicio, fim, penalidades):
    dist = { #dicionario que guarda menor custo conhecido do inicio até cada nó
    #dist["A"] = melhor custo conhecido para chegar em A a partir do início.
    #dist["B"] = melhor custo conhecido para chegar em B a partir do início.
    #etc....
        }
    prev = { #dicionario que guarda de onde eu vim( pontos que passei)
    #ex: prev["C"] = "A" significa o melhor caminho conhecido para chegar em C vem de A (antes de C eu passei por A)
        }
    visitados = set() #set() é conjunto vazio em python

    for n in caminhos.keys(): #".keys() pega todas as chaves de um dicionario, no caso, caminhos. For x in y é o loop for pegando todos os y e colocando em x"
        dist[n]=float("inf") #float("inf")=infinito em pyhton
        prev[n] = None

    dist[inicio]=0

    allNos = caminhos.keys() #coloquei todos os nós  que existem dentro de allNos
    while len(visitados) < len(allNos):
        melhorNo = None
        melhorDist = float("inf")
        for atual in allNos: #coloquei todos os nós dentro de atual
            if atual in visitados:
                continue   # "continue" = Pare o que você está fazendo nesta iteração do loop e vá para a próxima
            if dist[atual] < melhorDist:
                melhorNo=atual
                melhorDist=dist[atual]
        if melhorNo == None or melhorDist==float("inf"):
            break
        
        visitados.add(melhorNo)
        #print(melhorNo, melhorDist, visitados)

        for vizinho in caminhos[melhorNo]: #"caminhos[melhorNo]" é onde eu pego os vizinhos do melhorNo. Lembrando que "dicionario[chave]" = “me dá o valor guardado naquela chave”
            #print(vizinho, caminhos[melhorNo][vizinho])  #me dá os atributos da aresta que sai de melhorNo e vai até vizinho

            atributosAresta=caminhos[melhorNo][vizinho]
            d=atributosAresta[0]
            qtdSem=atributosAresta[1]
            qtdLomb=atributosAresta[2]
            v=atributosAresta[3]
            #print ("Teste: ", melhorNo, vizinho, d, qtdSem, qtdLomb, v)

            custoNovoTrecho = custoArestas(d, qtdSem, qtdLomb, v, penalidades)
            novoCusto = dist[melhorNo] + custoNovoTrecho
            #print("Teste 2: ", melhorNo, "->", vizinho , "custo_aresta=", custoNovoTrecho, "novoCusto=",novoCusto, "distAtualVizinho=", dist[vizinho])

            if novoCusto < dist[vizinho]:
                dist[vizinho] = novoCusto
                prev[vizinho] = melhorNo
                #print("Atualizei:", vizinho, "dist=", dist[vizinho], "prev=", prev[vizinho])

    caminhoTotal = reconstruirCaminho(prev, inicio, fim)

    return dist, prev, caminhoTotal, visitados

def reconstruirCaminho(prev, inicio, fim):
    caminho = []
    atual = fim
    while atual != None:
        caminho.append(atual) #.append(x) é um comando de lista que significa: .append(x) é um comando de lista que significa:
        if atual == inicio:
            break
        else:
            atual = prev[atual]
    caminho.reverse()
    
    #print(caminho)
    return caminho
    
#7-Esqueleto(executor do A*):
def a_estrela(caminhos, inicio, fim, penalidades, vertices):
    dist = { #dicionario que guarda menor custo conhecido do inicio até cada nó
    #dist["A"] = melhor custo conhecido para chegar em A a partir do início.
    #dist["B"] = melhor custo conhecido para chegar em B a partir do início.
    #etc....
        }
    prev = { #dicionario que guarda de onde eu vim( pontos que passei)
    #ex: prev["C"] = "A" significa o melhor caminho conhecido para chegar em C vem de A (antes de C eu passei por A)
        }
    visitados = set() #set() é conjunto vazio em python

    for n in caminhos.keys(): #".keys() pega todas as chaves de um dicionario, no caso, caminhos. For x in y é o loop for pegando todos os y e colocando em x"
        dist[n]=float("inf") #float("inf")=infinito em pyhton
        prev[n] = None

    dist[inicio]=0

    allNos = caminhos.keys() #coloquei todos os nós  que existem dentro de allNos
    while len(visitados) < len(allNos):
        melhorNo = None
        melhorF = float("inf")  #F de f(n)=g(n) (no código é o dist) + h(n) (no código é a função heuristica())
        for atual in allNos: #coloquei todos os nós dentro de atual
            if atual in visitados:
                continue   # "continue" = Pare o que você está fazendo nesta iteração do loop e vá para a próxima
            
            f_atual = dist[atual] + heuristica(atual, fim, vertices) #f(n) = g(n) + h(n)

            if f_atual < melhorF:
                melhorNo=atual
                melhorF=f_atual
        if melhorNo == None or melhorF==float("inf"):
            break
        
        visitados.add(melhorNo)
        if melhorNo == fim:
            break
        #print(melhorNo, dist[melhorNo], dist[melhorNo] + heuristica(melhorNo, fim, vertices))

        for vizinho in caminhos[melhorNo]: #"caminhos[melhorNo]" é onde eu pego os vizinhos do melhorNo. Lembrando que "dicionario[chave]" = “me dá o valor guardado naquela chave”
            #print(vizinho, caminhos[melhorNo][vizinho])  #me dá os atributos da aresta que sai de melhorNo e vai até vizinho

            atributosAresta=caminhos[melhorNo][vizinho]
            d=atributosAresta[0]
            qtdSem=atributosAresta[1]
            qtdLomb=atributosAresta[2]
            v=atributosAresta[3]
            #print ("Teste: ", melhorNo, vizinho, d, qtdSem, qtdLomb, v)

            custoNovoTrecho = custoArestas(d, qtdSem, qtdLomb, v, penalidades)
            novoCusto = dist[melhorNo] + custoNovoTrecho
            #print("Teste 2: ", melhorNo, "->", vizinho , "custo_aresta=", custoNovoTrecho, "novoCusto=",novoCusto, "distAtualVizinho=", dist[vizinho])

            if novoCusto < dist[vizinho]:
                dist[vizinho] = novoCusto
                prev[vizinho] = melhorNo
                #print("Atualizei:", vizinho, "dist=", dist[vizinho], "prev=", prev[vizinho])

    caminhoTotal = reconstruirCaminho(prev, inicio, fim)

    return dist, prev, caminhoTotal, visitados


def heuristica(no, fim, vertices):
    x0,y0=vertices[no]
    x,y=vertices[fim]
    hn = sqrt((x - x0)**2 + (y - y0)**2)/60
    #print("teste raiz: ", hn)

    return hn
