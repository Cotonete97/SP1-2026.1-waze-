def custoArestas(d, qtdSem, qtdLomb, v, penalidades):  #"penalidades" na main é = a pesos(), o que permite acessar o peso de semaforo e lombada
    tBase= d/v
    penTotal = qtdSem * penalidades["semaforo"] + qtdLomb * penalidades["lombada"]  #como "penalidades=pesos()" na main, "penalidades[x]" acessa o peso de x na função pesos
    custoTotal = tBase + penTotal

    return custoTotal

